# Alpaca paper trading (Phase 1)
# Get keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Telegram (Phase 2, optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Reddit (Phase 4, optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=amms/0.1

# Runtime
AMMS_DB_PATH=/data/amms.sqlite
AMMS_CONFIG_PATH=/app/config.yaml
AMMS_LOG_LEVEL=INFO

# Optional. When set, the scheduler exposes Prometheus metrics here.
# AMMS_METRICS_PORT=9100

# Optional. When set, daily Telegram summaries get a 1-paragraph LLM narration.
# ANTHROPIC_API_KEY=

# Optional. EDGAR client User-Agent identification; honor SEC's requirement.
# EDGAR_USER_AGENT=amms/0.1 (your-email@example.com)
