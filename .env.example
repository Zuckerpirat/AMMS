# Alpaca Paper Trading — get keys at https://app.alpaca.markets (paper account)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# Telegram (optional — leave blank to disable alerts)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Watchlist — comma-separated tickers scanned every morning
WATCHLIST=AAPL,MSFT,NVDA,AMD,TSLA,META,AMZN,GOOGL,SPY,QQQ

# Strategy tuning
MOMENTUM_LOOKBACK=20
VOLUME_MULTIPLIER=1.5

# Risk limits
MAX_POSITION_PCT=0.05
MAX_OPEN_POSITIONS=10
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.15
MIN_STOCK_PRICE=1.0
MAX_STOCK_PRICE=500.0

# Storage
DB_PATH=data/amms.db

# Control API
API_HOST=0.0.0.0
API_PORT=8000
